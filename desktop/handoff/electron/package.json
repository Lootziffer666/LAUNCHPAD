    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "//": "NOTE: keep React pinned to 18.3.1 to match the prototype. Add argon2/scrypt for PIN hashing in M4."
