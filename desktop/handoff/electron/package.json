{
  "name": "launchpad",
  "version": "0.1.0",
  "description": "LAUNCHPAD — a kid-safe desktop shell for Windows (Electron + React + Vite).",
  "main": "electron/main.js",
  "author": "",
  "license": "UNLICENSED",
