<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/em_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Dashboard Card ── -->
            <LinearLayout
                android:id="@+id/em_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/lp_peach"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/em_balance_big"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="— Min"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/lp_ink" />

                    <TextView
                        android:id="@+id/em_mode_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SETUP"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#FF6B35"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/em_balance_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verfügbares Zeitguthaben"
                    android:textSize="12sp"
                    android:textColor="@color/lp_ink_soft"
                    android:paddingTop="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33000000"
                    android:layout_marginVertical="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/em_last_tx"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Keine Transaktionen"
                        android:textSize="12sp"
                        android:textColor="@color/lp_ink_soft" />

                    <TextView
                        android:id="@+id/em_enforcement_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kindermodus AUS"
                        android:textSize="12sp"
                        android:textColor="@color/lp_ink_soft" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33000000"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/em_today_used"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Heute genutzt: —"
                    android:textSize="12sp"
                    android:textColor="@color/lp_ink_soft" />

                <TextView
                    android:id="@+id/em_top_apps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/lp_ink_soft"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <!-- ── Section: Zeit ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Zeit &amp; Guthaben" />

            <LinearLayout android:id="@+id/em_row_add_time"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Heute Ausnahme" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+" android:textSize="24sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_transactions"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Transaktions-Verlauf" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_tagesbericht"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Tagesbericht" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_wochenplan"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Wochenplan" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <!-- ── Section: Apps ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Apps" />

            <LinearLayout android:id="@+id/em_row_apps"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Apps verwalten" />
                    <TextView android:id="@+id/em_apps_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 Apps freigegeben"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <!-- ── Section: Inhalte ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Wünsche &amp; Inhalte" />

            <LinearLayout android:id="@+id/em_row_zusagen"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Versprechen (Zusagen)" />
                    <TextView android:id="@+id/em_zusagen_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keine aktiven Versprechen"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_doge"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Medien-Anfragen" />
                    <TextView android:id="@+id/em_doge_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keine offenen Anfragen"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_time_requests"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mehr-Zeit-Anfragen" />
                    <TextView android:id="@+id/em_time_requests_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keine offenen Anfragen"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <!-- ── Section: Modus ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Kindermodus" />

            <RelativeLayout android:id="@+id/em_row_kindermodus"
                style="@style/SettingsHolderSwitchStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background">
                <org.fossify.commons.views.MyMaterialSwitch
                    android:id="@+id/em_kindermodus_switch"
                    style="@style/SettingsSwitchStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Erlaubte Apps + Zeitbudget" />
            </RelativeLayout>

            <RelativeLayout android:id="@+id/em_row_school"
                style="@style/SettingsHolderSwitchStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background">
                <org.fossify.commons.views.MyMaterialSwitch
                    android:id="@+id/em_school_switch"
                    style="@style/SettingsSwitchStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Schulmodus jetzt (manuell)" />
            </RelativeLayout>

            <LinearLayout android:id="@+id/em_row_school_times"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Schulzeiten (automatisch)" />
                    <TextView android:id="@+id/em_school_times_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Aus"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_cooldown_rules"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Ruhezeiten konfigurieren" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_hinweise"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Hinweise &amp; Vibration" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_child_name"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Name des Kindes" />
                    <TextView android:id="@+id/em_child_name"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Jake"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <!-- ── Section: Sicherheit ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Schutz &amp; Status" />

            <LinearLayout android:id="@+id/em_row_health"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Status-Check" />
                    <TextView android:id="@+id/em_health_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Berechtigungen prüfen"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_audit"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Verlauf &amp; Ereignisse" />
                    <TextView android:id="@+id/em_audit_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keine besonderen Ereignisse"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_strict_block"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lückenloser App-Schutz" />
                    <TextView android:id="@+id/em_strict_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Aus"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_usage"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nutzungszugriff (Zeitmessung)" />
                    <TextView android:id="@+id/em_usage_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nicht erteilt"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <RelativeLayout android:id="@+id/em_row_kiosk"
                style="@style/SettingsHolderSwitchStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background">
                <org.fossify.commons.views.MyMaterialSwitch
                    android:id="@+id/em_kiosk_switch"
                    style="@style/SettingsSwitchStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Geschützter Modus (optional)" />
            </RelativeLayout>

            <!-- ── Section: Erweitert ── -->
            <TextView style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:text="Mehr" />

            <LinearLayout android:id="@+id/em_row_qr"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Eltern-App koppeln (QR)" />
                    <TextView android:id="@+id/em_pair_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nicht gekoppelt"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <LinearLayout android:id="@+id/em_row_familylink"
                style="@style/SettingsHolderTextViewOneLinerStyle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/ripple_background" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <org.fossify.commons.views.MyTextView style="@style/SettingsTextLabelStyle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fern-Zugriff &amp; Family Link" />
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="App-Freigaben &amp; mehr Zeit von unterwegs"
                        android:textSize="12sp" android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="?colorPrimary" />
            </LinearLayout>

            <android.view.View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
