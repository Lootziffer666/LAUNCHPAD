<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lp_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="140dp"
            android:src="@drawable/mascot_rocket_rest"
            android:contentDescription="@null"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/cooldown_timer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15:00"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/lp_coral"
            android:fontFamily="monospace"
            android:paddingBottom="16dp" />

        <ProgressBar
            android:id="@+id/cooldown_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="15"
            android:progress="15"
            android:progressTint="@color/lp_mint"
            android:paddingBottom="24dp" />

        <TextView
            android:id="@+id/cooldown_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/lp_ink"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- CooldownActivity injects a title at index 0 and adds activity buttons here. -->
        <LinearLayout
            android:id="@+id/cooldown_app_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
