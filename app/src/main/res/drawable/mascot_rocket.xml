    android:width="120dp"
    android:height="140dp"
    android:viewportWidth="120"
    android:viewportHeight="140">

    <!-- flame -->
    <path android:fillColor="#FFC53D"
        android:pathData="M50,112 C50,126 56,134 60,139 C64,134 70,126 70,112 Z" />
    <path android:fillColor="#FF7A59"
        android:pathData="M55,113 C55,123 58,129 60,133 C62,129 65,123 65,113 Z" />

